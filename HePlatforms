Platform linux64-debug
IsDebug
ExecExtension -debug
LibExtension -debug.so
Compiler gcc
RaylibLdFlag -lraylib

Platform win32
IsRelease
ExecExtension .exe
LibExtension .dll
Compiler i686-w64-mingw32-gcc
CxxCompiler i686-w64-mingw32-g++
RaylibLdFlag -lraylib
ExtraLDFlag -static-libstdc++
ExtraLDFlag -static-libgcc

# Libraries
ExtraLDFlag -lws2_32
ExtraLDFlag -lwinmm
ExtraLDFlag -lopengl32
ExtraLDFlag -lgdi32
ExtraLDFlag -lbcrypt

# flags for EAWebKit code compilation
ExtraCFlag -DEAWEBKIT_PLATFORM_HEADER="<windows.h>"

# EAWebKit flags for compatibility with SimCity's EAWebKit
ExtraCFlag -DEAWEBKIT_DEFAULT_FILE_SYSTEM_ENABLED=0

